    "lint": "eslint src/**/*.js",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VildeAvloes/semester-project-2.git"
  },
  "keywords": [
    "semester-project-2",
    "web-app"
  ],
  "author": "Vilde Avloes <vildeavlos@gmail.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/VildeAvloes/semester-project-2/issues"
  },
  "homepage": "https://github.com/VildeAvloes/semester-project-2#readme",
  "devDependencies": {
    "eslint": "^8.56.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.html": [
      "prettier --write"
    ],
    "*.scss": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "bootstrap": "^5.2.0"
