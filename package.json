{
  "name": "semester-project-2",
  "version": "1.0.0",
  "description": "An ficitve auction website created for the Semester Project 2 at the Noroff Front-End developer educational programme. ",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
